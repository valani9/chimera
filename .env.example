# CHIMERA Configuration
# Copy to .env and fill in your API keys

# LLM API Keys (need at least one)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...

# Polymarket CLOB API Credentials
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
PRIVATE_KEY=  # Polygon wallet private key (0x...)

# Runtime
BANKROLL=1000.0
PAPER_TRADING=true
